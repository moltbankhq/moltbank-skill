{
  "name": "moltbank",
  "version": "0.2.0",
  "description": "Moltbank skill with CLI-first treasury guidance plus security-first generic operating rules for installing, inspecting, running, updating, and removing Moltbank Mods.",
  "homepage": "https://app.moltbank.bot",
  "entrypoint": "SKILL.md",
  "requirements": {
    "bins": ["moltbank"],
    "node": ">=22.0.0"
  },
  "mcpServers": {
    "Moltbank": {
      "description": "Local Moltbank stdio MCP bridge",
      "transport": "stdio",
      "command": "moltbank",
      "args": ["mcp", "stdio"],
      "env": {
        "MOLTBANK_CREDENTIALS_PATH": "${MOLTBANK_CREDENTIALS_PATH}"
      }
    }
  }
}
