# Used by `pnpm docs:render:local` to generate SKILL.local.md that points
# at a locally-linked checkout of the openclaw-npm CLI and the local HTTPS
# dev URL, instead of the published npm package + production URL.
#
# Copy this file to .env and adjust the paths for your machine.

# Absolute or relative (from moltbank-skill/) path to the openclaw-npm repo.
# Must contain a package.json that exposes a "moltbank" bin.
LOCAL_OPENCLAW_PATH=../openclaw-npm

# Optional: override the homepage URL baked into SKILL.local.md.
# Defaults to the local HTTPS dev origin used by APP/.
LOCAL_HOMEPAGE_URL=https://localtest.app.moltbank.bot
